# Configuration du Bot Crypto News FR
# 📋 COPIER CE FICHIER vers 'config.py' et remplir avec vos vraies clés
# ⚠️ NE JAMAIS COMMITER config.py sur GitHub !

# ===== API KEYS =====
# Obtenir un token bot: https://t.me/BotFather
BOT_TOKEN = "YOUR_TELEGRAM_BOT_TOKEN_HERE"

# Obtenir une clé API: https://platform.openai.com/api-keys
OPENAI_API_KEY = "YOUR_OPENAI_API_KEY_HERE"

# ===== TELEGRAM =====
# Votre canal crypto francophone 
# Format: "@nomducanal" pour canal public
# Format: "-1001234567890" pour groupe privé
CHAT_ID = "@your_channel_here"
CHANNEL_ID = CHAT_ID  # Utilisé par le bot pour compatibilité

# ===== FRÉQUENCE DES POSTS =====
# Choisissez votre intervalle de posting:
POST_INTERVAL_MINUTES = 5  # Toutes les 5 minutes - Maximum réactivité!

# Autres options:
# POST_INTERVAL_MINUTES = 15   # Toutes les 15 minutes
# POST_INTERVAL_MINUTES = 60   # Toutes les heures  
# POST_INTERVAL_MINUTES = 120  # Toutes les 2 heures

# ===== FONCTIONNALITÉS =====
# Nombre d'articles à récupérer par cycle
MAX_ARTICLES_PER_CYCLE = 5

# Délai entre chaque post (en secondes) pour éviter le spam
DELAY_BETWEEN_POSTS = 5

# Génération d'images avec DALL-E (True/False)
GENERATE_IMAGES = True  # Mettre False pour désactiver les images

# ===== CHATGPT =====
# Modèle OpenAI à utiliser
OPENAI_MODEL = "gpt-3.5-turbo"  # Plus économique
# OPENAI_MODEL = "gpt-4o"       # Plus performant mais plus cher

# ===== LOGGING =====
# Niveau de logs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL = "INFO"

# ===== MESSAGE FORMAT =====
# Emojis et style des messages
CRYPTO_EMOJIS = ["🚀", "📈", "💎", "⚡", "🌟", "🔥", "🌙", "💰"]
HASHTAGS = ["#CryptoNews", "#Bitcoin", "#Blockchain", "#DeFi", "#Crypto"]

# ===== RSS FEEDS =====
RSS_FEEDS = [
    "https://www.benzinga.com/rss",  # Benzinga Crypto News
]
