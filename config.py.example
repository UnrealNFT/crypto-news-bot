# Configuration du Bot Crypto News FR
# Copier ce fichier vers 'config.py' et remplir avec vos vraies cles
# Ne jamais commiter config.py sur GitHub !

# ===== API KEYS =====
# Obtenir un token bot: https://t.me/BotFather
BOT_TOKEN = ""

# ===== TELEGRAM =====
# Votre canal crypto francophone 
# Format: "@nomducanal" pour canal public
# Format: "-1001234567890" pour groupe prive
CHAT_ID = ""
CHANNEL_ID = CHAT_ID

# ===== FREQUENCE DES POSTS =====
POST_INTERVAL_MINUTES = 5

# ===== FONCTIONNALITES =====
MAX_ARTICLES_PER_CYCLE = 5
DELAY_BETWEEN_POSTS = 5

# ===== GENERATION D'IMAGES FLUX.1 =====
# Active la generation d'images avec FLUX.1 (CPU, lent mais gratuit)
GENERATE_IMAGES = False
# Active la superposition du logo sur les images generees
ADD_LOGO = True
# Position du logo: "top-left", "top-right", "bottom-left", "bottom-right"
LOGO_POSITION = "top-left"
# Taille du logo en pixels
LOGO_SIZE = 200

# ===== LOGGING =====
LOG_LEVEL = "INFO"

# ===== MESSAGE FORMAT =====
CRYPTO_EMOJIS = ["", "", "", "", "", "", "", ""]
HASHTAGS = ["#CryptoNews", "#Bitcoin", "#Blockchain", "#DeFi", "#Crypto"]

# ===== RSS FEEDS =====
RSS_FEEDS = [
    "https://www.benzinga.com/rss",
]
